<% if message.role == "user" %>
  <div class="message-row user-row">
    <div class="chat-bubble user-bubble">
      <%= raw(render_markdown(message.content)) %>
    </div>
  </div>
<% elsif message.role == "assistant" %>
  <div class="message-row assistant-row" id="<%= dom_id(message) %>">
    <div class="assistant-avatar">
      <svg viewBox="0 0 352.35 470.27" xmlns="http://www.w3.org/2000/svg">
        <circle cx="176.17" cy="298.10" r="172.17" fill="#780000"/>
        <circle cx="176.17" cy="176.17" r="172.17" fill="none" stroke="#1a1a1a" stroke-miterlimit="10" stroke-width="8"/>
      </svg>
    </div>
    <div class="chat-bubble assistant-bubble">
      <%= message.content.present? ? raw(render_markdown(message.content)) : "..." %>
    </div>
  </div>
<% end %>
