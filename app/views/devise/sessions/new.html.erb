
<div class="login_container">
  <p></p>

  <h2>Log in</h2>

  <p>

  </p>
  <div class="form-inputs login-inputs row justify-content-center ">
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <%= f.input :email,
                  required: false,
                  autofocus: true,
                  input_html: { autocomplete: "email", class: "login_fields" } %>

      <%= f.input :password,
                  required: false,
                  input_html: { autocomplete: "current-password", class: "login_fields" } %>
      <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>

    <div class="form-actions">

      <div class="home-hero-actions">
        <button> <span> <%= f.button :submit, "Log in" %></span>
        </button>
      </div>
    </div>
      <%= render "devise/shared/links" %>
    <% end %>

</div>
