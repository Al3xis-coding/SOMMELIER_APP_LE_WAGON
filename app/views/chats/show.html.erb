<div class="chat-page">
  <% hero_titles = [
    "Tell me what's on your plate and let's find out the perfect pour.",
    "What's the occasion? I'll find the right bottle.",
    "Most people guess. You, wisely, are asking. What's on the menu?",
    "A great meal deserves a great wine. Let's find it.",
    "Tell me about your evening and I'll do the rest.",
    "Every dish has its match. Let's find yours.",
  ] %>
  <div class="chat-hero">
    <p class="chat-hero-title"><%= hero_titles.sample %></p>
  </div>

  <div class="chat-messages" id="messages" data-controller="autoscroll">
    <%= render "messages/messages", messages: @chat.messages %>
  </div>

  <div class="chat-input-area" id="new_message_container">
    <%= render "messages/form", chat: @chat, message: @message %>
  </div>
<%= turbo_stream_from @chat %>
</div>
