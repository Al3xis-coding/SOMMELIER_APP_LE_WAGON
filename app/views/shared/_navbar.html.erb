      <span class="navbar-brand-name">gr<span class="navbar-brand-ai">AI</span>pes</span>
    <% end %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <div class="navbar-nav-pills">
        <% if user_signed_in? %>
          <%= link_to wines_path, class: "nav-pill-btn #{current_page?(wines_path) ? 'active' : ''}" do %>
            <span>Wine List</span>
          <% end %>
          <%= link_to chats_path, data: { turbo_method: :post }, class: "nav-pill-btn #{controller_name == 'chats' ? 'active' : ''}" do %>
            <span>Sommelier</span>
