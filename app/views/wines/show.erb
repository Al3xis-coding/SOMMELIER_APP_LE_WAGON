<div class="card mb-3 shadow-sm">
  <div class="card-body">
    <div class="d-flex align-items-center mb-2">
      <span class="badge rounded-pill
        <%= case @wine.color
            when 'red' then 'bg-danger'
            when 'white' then 'bg-warning text-dark'
            when 'rosé' then 'bg-pink'
            when 'yellow' then 'bg-warning'
            end %> me-2">
        <%= @wine.color.capitalize %>
      </span>
      <% if @wine.origin.present? %>
        <small class="text-muted"><%= @wine.origin %></small>
      <% end %>
    </div>

    <% if @wine.categories.present? %>
      <h5 class="card-title"><%= @wine.categories %></h5>
    <% end %>

    <% if @wine.description.present? %>
      <p class="card-text"><%= @wine.description %></p>
    <% end %>
  </div>
</div>
