<div class="home-hero">
  <div class="home-hero-content">
    <h1 class="home-hero-title reveal" data-reveal>
      gr<span class="home-hero-title-ai">AI</span>pes
    </h1>
    <p class="home-hero-description reveal" data-reveal data-reveal-delay="600">
      Discover the perfect wine for every occasion. Let our AI sommelier guide you through a world of flavors, aromas, and pairings.
    </p>
    <div class="home-hero-actions reveal" data-reveal data-reveal-delay="600">
      <%= link_to chats_path, data: { turbo_method: :post }, class: "nav-pill-btn nav-pill-btn--cta" do %>
        <span>Get Started</span>
      <% end %>
    </div>
  </div>

  <div class="home-hero-visual">
    <svg class="sommelier-logo" viewBox="0 0 352.35 854.47" xmlns="http://www.w3.org/2000/svg">
      <circle class="logo-base" cx="176.17" cy="678.29" r="172.17" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="8"/>
      <line class="logo-stem" x1="176.17" y1="470.28" x2="176.17" y2="678.29" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="8"/>
      <circle class="logo-wine" cx="176.17" cy="298.10" r="172.17" fill="#780000"/>
      <circle class="logo-rim" cx="176.17" cy="176.17" r="172.17" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="8"/>
    </svg>
  </div>
</div>
